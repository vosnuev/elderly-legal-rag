# Streamlit environment example
STREAMLIT_APP_TITLE="법률 RAG 프론트"
STREAMLIT_PAGE_TITLE="법률 RAG 프론트"
STREAMLIT_LAYOUT="wide"
STREAMLIT_BACKEND_BASE_URL="http://127.0.0.1:8000"
STREAMLIT_BACKEND_TIMEOUT_SECONDS=15
# false면 Streamlit 임시 데이터로 동작, true면 backend /api/chat 호출
STREAMLIT_USE_BACKEND_API=false
