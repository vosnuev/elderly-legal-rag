# Streamlit environment example
STREAMLIT_APP_TITLE="법률 RAG 프론트"
STREAMLIT_PAGE_TITLE="법률 RAG 프론트"
STREAMLIT_LAYOUT="wide"
STREAMLIT_INITIAL_SIDEBAR_STATE="expanded"
STREAMLIT_BACKEND_BASE_URL="http://127.0.0.1:8000"
STREAMLIT_BACKEND_TIMEOUT_SECONDS=15
# true면 backend agent.stream 응답을 흉내낸 mock generator를 사용
# false면 backend /chat endpoint를 호출
STREAMLIT_CHAT_BACKEND_MOCK=true
STREAMLIT_CHAT_MOCK_CHUNK_DELAY_SECONDS=0.02
STREAMLIT_LOG_LLM_CONTEXT=false
