# Backend environment example
#
# 실제 키는 backend/.env에만 넣고 커밋하지 않는다.

# Required
# Settings accepts both BACKEND_OPENROUTER_API_KEY and OPENROUTER_API_KEY.
# Keep BACKEND_OPENROUTER_API_KEY as the project-local .env convention.
BACKEND_OPENROUTER_API_KEY=""

# Optional service metadata
BACKEND_SERVICE_NAME="SKN28 Backend"
BACKEND_SERVICE_VERSION="0.1.0"
BACKEND_LANGCHAIN_PROJECT=""

# OpenRouter
BACKEND_OPENROUTER_MODEL="openai/gpt-oss-120b"
BACKEND_OPENROUTER_APP_TITLE="SKN28 Backend Agent"
BACKEND_OPENROUTER_APP_URL="https://openrouter.ai/openai/gpt-oss-120b"
BACKEND_OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# OpenRouter provider routing
# no_tool benchmark 기준과 맞춰 Cerebras fp16을 우선 사용하고 fallback을 막는다.
BACKEND_OPENROUTER_PROVIDER_ORDER='["cerebras/fp16"]'
BACKEND_OPENROUTER_ALLOW_FALLBACKS=false
BACKEND_OPENROUTER_REQUIRE_PARAMETERS=false

# Local runtime
BACKEND_API_HOST="127.0.0.1"
BACKEND_API_PORT=8000
BACKEND_RELOAD=false
BACKEND_CORS_ORIGINS='["http://localhost:8501","http://127.0.0.1:8501","http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://127.0.0.1:3000"]'

# Docker compose runtime
# docker-compose.yml은 컨테이너 내부 bind host를 항상 0.0.0.0으로 고정하고,
# 아래 값은 host publish 주소/포트만 정한다. 8000을 이미 쓰고 있으면 8001을 유지한다.
BACKEND_HOST_BIND="127.0.0.1"
BACKEND_HOST_PORT=8001

# LLM tuning
BACKEND_LLM_TEMPERATURE=0.2
BACKEND_LLM_TIMEOUT_MS=60000
BACKEND_LLM_MAX_RETRIES=2
# Optional. Leave empty to omit reasoning_effort from OpenRouter requests.
BACKEND_LLM_REASONING_EFFORT=""

# MCP Tool Server
BACKEND_RAG_MCP_URL="http://127.0.0.1:8010/mcp"
BACKEND_TOOL_TIMEOUT_MS=30000

# Logging
BACKEND_LOG_LEVEL="INFO"
BACKEND_LOG_LLM_CONTEXT=true

# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="skn28-backend-agent-dev"
LANGCHAIN_CALLBACKS_BACKGROUND=false
