BACKEND_SERVICE_NAME="SKN28 Backend"
BACKEND_SERVICE_VERSION="0.1.0"
BACKEND_API_HOST="127.0.0.1"
BACKEND_API_PORT=8000
BACKEND_RELOAD=false
# 프론트 개발 서버 주소 (Vite 기본: 5173, CRA 기본: 3000)
BACKEND_CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'
BACKEND_LANGCHAIN_PROJECT=""

# OPENROUNTER
BACKEND_OPENROUTER_API_KEY=""
BACKEND_OPENROUTER_MODEL="openai/gpt-oss-120b"
BACKEND_OPENROUTER_PROVIDER_ORDER='["cerebras"]'
BACKEND_OPENROUTER_ALLOW_FALLBACKS=true
BACKEND_OPENROUTER_APP_TITLE="SKN28 Backend Agent"
BACKEND_OPENROUTER_APP_URL="https://openrouter.ai/openai/gpt-oss-120b"

# LLM
BACKEND_LLM_TEMPERATURE=0.2
BACKEND_LLM_TIMEOUT_MS=60000
BACKEND_LLM_MAX_RETRIES=2
# Optional. Leave empty to omit reasoning_effort from OpenRouter requests.
BACKEND_LLM_REASONING_EFFORT=""

# Logging
BACKEND_LOG_LEVEL="INFO"
BACKEND_LOG_LLM_CONTEXT=true

# Langsmith
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="skn28-backend-agent-dev"
LANGCHAIN_CALLBACKS_BACKGROUND=false
