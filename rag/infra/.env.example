# Copy this file to infra/.env before running docker compose.

# Bind published container ports to localhost so they are safe to expose through
# SSH / VS Code port forwarding from a client machine.
MEMGRAPH_PUBLISH_HOST=127.0.0.1

# Memgraph DB container
MEMGRAPH_IMAGE=memgraph/memgraph-mage:latest
MEMGRAPH_CONTAINER_NAME=rag-memgraph
MEMGRAPH_BOLT_PORT=7687
MEMGRAPH_LOG_PORT=7444
MEMGRAPH_LOG_LEVEL=INFO
MEMGRAPH_SCHEMA_INFO_ENABLED=true

# Memgraph Lab container
MEMGRAPH_LAB_IMAGE=memgraph/lab:latest
MEMGRAPH_LAB_CONTAINER_NAME=rag-memgraph-lab
MEMGRAPH_LAB_PORT=3000

# Redis container for RAG backend observability streams
REDIS_IMAGE=redis:7-alpine
REDIS_CONTAINER_NAME=rag-redis
REDIS_PUBLISH_HOST=127.0.0.1
REDIS_PORT=6379

# Optional Memgraph auth. If enabled, also update rag/.env.
# MEMGRAPH_USER=rag
# MEMGRAPH_PASSWORD=change-me
