# RAG service directories
RAG_WORKSPACE_DIR="./workspace"
RAG_INPUT_DIR="./input"
RAG_OUTPUT_DIR="./output"
RAG_CACHE_DIR="./cache"

# Memgraph connection. Local DB is managed by rag/infra/docker-compose.yml.
RAG_MEMGRAPH_URI="bolt://127.0.0.1:7687"
RAG_MEMGRAPH_USERNAME=""
RAG_MEMGRAPH_PASSWORD=""

# Redis-backed job observability streams
RAG_REDIS_URL="redis://127.0.0.1:6379/0"
RAG_OBSERVABILITY_ENABLED=true
RAG_OBSERVABILITY_STREAM_PREFIX="rag:observability:jobs"
RAG_OBSERVABILITY_STREAM_MAXLEN=2000
RAG_OBSERVABILITY_STREAM_TTL_SECONDS=3600
RAG_OBSERVABILITY_XREAD_BLOCK_MS=15000

# OpenRouter / model settings
RAG_OPENROUTER_API_KEY=""
RAG_OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
RAG_GRAPH_LLM_MODEL="openai/gpt-oss-120b"
RAG_GRAPH_LLM_PROVIDER="groq"
RAG_GRAPH_LLM_PROVIDER_ALLOW_FALLBACKS=true
RAG_GRAPH_LLM_RETRY_WITHOUT_PROVIDER=true
RAG_GRAPH_LLM_REQUEST_TIMEOUT_SECONDS=60
RAG_GRAPH_LLM_STREAM_CHUNK_TIMEOUT_SECONDS=60
RAG_GRAPH_LLM_MAX_RETRIES=2
RAG_GRAPH_LLM_THINKING=""
RAG_EMBEDDING_MODEL="openai/text-embedding-3-large"
RAG_EMBEDDING_DIMENSIONS=3072
RAG_EMBEDDING_WORKER_COUNT=5

# FastMCP Streamable HTTP endpoint
RAG_MCP_HOST="127.0.0.1"
RAG_MCP_PORT=8010
RAG_EXTERNAL_MCP_PATH="/mcp"
RAG_CORS_ALLOWED_ORIGINS='["http://127.0.0.1:5173","http://localhost:5173"]'

# Memgraph query execution guardrails
RAG_QUERY_TIMEOUT_MS=30000
RAG_QUERY_MAX_ROWS=100
RAG_TEXT_SEARCH_INDEX_NAME="rag_text_idx"
RAG_DOCUMENT_TEXT_SEARCH_INDEX_NAME="rag_document_text_idx"
RAG_REVIEW_NOTE_TEXT_SEARCH_INDEX_NAME="rag_review_note_text_idx"
RAG_GRAPH_CANDIDATE_TOOL_BUDGET=80
RAG_GRAPH_CANDIDATE_WORKER_COUNT=8
RAG_KNOWLEDGE_BUILD_WORKER_COUNT=1
RAG_KNOWLEDGE_REVIEW_WORKER_COUNT=2
RAG_KNOWLEDGE_TASK_QUEUE_MAX_SIZE=100
RAG_GRAPH_CONSTRUCTION_WORKER_COUNT=1
RAG_GRAPH_REVIEW_WORKER_COUNT=2
RAG_GRAPH_TASK_QUEUE_MAX_SIZE=100

# Structured logging
RAG_LOG_LEVEL="INFO"
RAG_LOG_JSON=true

# Legacy standalone data collection scripts may need these if they are restored.
# They are not loaded by src/settings.py.
# OPENAI_API_KEY=your-openai-api-key
# DEFAULT_MODEL=gpt-4o-mini
# MODERATION_MODEL=omni-moderation-latest
# LAW_API_KEY=your-law-api-key
# SENIOR_API_KEY=your-senior-api-key
# WORKNET_API_KEY=your-worknet-api-key
# KOSIS_API_KEY=your-kosis-api-key
