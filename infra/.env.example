# Root integrated Compose environment example.
# Copy to infra/.env for non-secret host port overrides.

MEMGRAPH_PUBLISH_HOST=127.0.0.1
MEMGRAPH_IMAGE=memgraph/memgraph-mage:latest
MEMGRAPH_CONTAINER_NAME=rag-memgraph
MEMGRAPH_BOLT_PORT=7687
MEMGRAPH_LOG_PORT=7444
MEMGRAPH_LOG_LEVEL=INFO
MEMGRAPH_SCHEMA_INFO_ENABLED=true

MEMGRAPH_LAB_IMAGE=memgraph/lab:latest
MEMGRAPH_LAB_CONTAINER_NAME=rag-memgraph-lab
MEMGRAPH_LAB_PORT=3000

REDIS_IMAGE=redis:7-alpine
REDIS_CONTAINER_NAME=rag-redis
REDIS_PUBLISH_HOST=127.0.0.1
REDIS_PORT=6379

RAG_BE_PUBLISH_HOST=127.0.0.1
RAG_BE_HOST_PORT=8110

BACKEND_PUBLISH_HOST=127.0.0.1
BACKEND_HOST_PORT=8100

STREAMLIT_PUBLISH_HOST=127.0.0.1
STREAMLIT_HOST_PORT=8501

RAG_FE_PUBLISH_HOST=127.0.0.1
RAG_FE_HOST_PORT=5174
RAG_FE_PUBLIC_RAG_API_BASE_URL=http://127.0.0.1:8110
RAG_FE_PUBLIC_RAG_API_TIMEOUT_MS=1500
RAG_FE_PUBLIC_RAG_ENABLE_MOCK_FALLBACK=false
RAG_FE_PUBLIC_MEMGRAPH_LAB_URL=http://127.0.0.1:3000
